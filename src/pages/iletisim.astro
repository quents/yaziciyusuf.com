---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="İletişim — Yusuf Yazıcı">
  <section class="section" style="border:none;padding-top:2.5rem;">
    <div class="container">
      <h1 style="margin-bottom:0.5rem;">İletişim</h1>
      <p style="color:var(--text-2);margin-bottom:2rem;font-size:0.95rem;">
        Benimle iletişime geçmek için formu kullanabilir veya sosyal medya hesaplarımdan ulaşabilirsiniz.
      </p>

      <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <div class="form-field">
          <label for="name">Adınız</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="form-field">
          <label for="email">E-posta</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-field">
          <label for="message">Mesajınız</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        <button type="submit" class="btn">Gönder</button>
      </form>

      <div style="margin-top:2.5rem;padding-top:1.5rem;border-top:1px solid var(--border);">
        <p style="font-size:0.88rem;color:var(--text-2);">
          <a href="https://github.com/quents" target="_blank">GitHub</a> ·
          <a href="https://linkedin.com/in/yusufyazici" target="_blank">LinkedIn</a> ·
          <a href="mailto:mail@yaziciyusuf.com">mail@yaziciyusuf.com</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
