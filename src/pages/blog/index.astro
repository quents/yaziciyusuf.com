---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog — Yusuf Yazıcı">
  <section class="section" style="border:none;padding-top:2.5rem;">
    <div class="container">
      <h1 style="margin-bottom:2rem;">Blog</h1>
      {posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="post-item">
              <p class="post-item__date">
                {new Date(post.data.date).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h3 class="post-item__title">{post.data.title}</h3>
              <p class="post-item__excerpt">{post.data.excerpt}</p>
            </a>
          ))}
        </div>
      ) : (
        <p style="color:var(--text-3);">Henüz yazı yok.</p>
      )}
    </div>
  </section>
</BaseLayout>
